# 「热读」内容引擎环境变量样例
# 用法：cp .env.example .env  然后按需修改

# -------- PostgreSQL --------
POSTGRES_USER=rd
POSTGRES_PASSWORD=rd
POSTGRES_DB=redu
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# SQLAlchemy 直接读这一条
DATABASE_URL=postgresql+psycopg://rd:rd@localhost:5432/redu

# -------- Redis --------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# -------- LLM（兼容 OpenAI 格式即可） --------
# 不设则摘要走抽取式兜底
RD_LLM_API_KEY=
RD_LLM_BASE_URL=https://api.openai.com/v1
RD_LLM_MODEL=gpt-4o-mini
# 阶段 3.1：调用韧性（令牌桶限流 QPS + 重试次数 + 指数退避基数(秒) + 单次超时(秒)）
RD_LLM_RATE_PER_SEC=3.0
RD_LLM_MAX_RETRIES=3
RD_LLM_BACKOFF_BASE=1.0
RD_LLM_TIMEOUT=60

# -------- 管线阈值（与 pipeline_demo/config.py 默认值对齐） --------
RD_DEDUP_THRESHOLD=0.92
RD_CLUSTER_THRESHOLD=0.86
RD_MAX_PER_SOURCE=12
# SimHash 近似去重：汉明距离 ≤ 阈值视为重复（64-bit 经验值 ≤3）
RD_SIMHASH_HAMMING_THRESHOLD=3
RD_SIMHASH_WINDOW_HOURS=72
# 信源健康：连续失败 N 次触发控制台 WARNING
RD_SOURCE_FAILURE_ALERT_THRESHOLD=3
# 阶段 2.1：分类置信度低于此阈值时调用 LLM 兜底（前提：RD_LLM_API_KEY 已配置）
RD_CLS_LLM_THRESHOLD=0.6

# -------- 阶段 3.4：Redis 榜单（ZSet） --------
# 关闭则评分不写榜、/ranking 自动降级回 DB importance 排序
RD_RANK_ENABLED=true
# 每个 ZSet 最多保留多少条（按 importance 裁尾）
RD_RANK_KEEP=500

# -------- 阶段 4.1：发布前防幻觉护栏 --------
# 总开关：关闭则 publish 阶段直接放行（仅本地调试）
RD_GUARD_ENABLED=true
# detail 摘要中查无信源出处的数字占比 > 此值 → 拦截进人工
RD_GUARD_MAX_UNVERIFIED_NUMBER_RATIO=0.5
# card/detail 摘要最短中文字符数（过短视为生成异常）
RD_GUARD_MIN_SUMMARY_CHARS=10
# 追加敏感词（逗号分隔），与内置基础词表合并
RD_GUARD_SENSITIVE_WORDS=

# -------- 阶段 4.2：CMS 质检后台鉴权 --------
# 质检接口 X-Admin-Token 头校验；为空则所有质检请求 401
RD_ADMIN_TOKEN=

# -------- 阶段 4.3：Celery 调度 --------
# broker / result backend（默认复用 Redis）
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
